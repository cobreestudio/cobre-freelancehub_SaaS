# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (Settings > API > service_role)
# Never expose this in the browser — only used in server-side API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From address for automated payment reminder emails
# Must be a verified domain in Resend (or use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Secret to protect the /api/send-reminders cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-string

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID of the Pro plan product in Stripe (Dashboard > Products > your Pro plan > Price ID)
STRIPE_PRO_PRICE_ID=price_...

# Public URL of your deployed app (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Upstash Redis — https://console.upstash.com
# Used for rate limiting AI endpoints (20 req/h per user)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
